#Copy this file to .env.local for local Docker testing.
#Never commit real secrets to git.
#---------- Postgres ----------
POSTGRES_DB=knowted_db
POSTGRES_USER=knowted
POSTGRES_PASSWORD=knowted_local_password
POSTGRES_HOST_PORT=5433

#---------- Backend ----------
SPRING_PROFILES_ACTIVE=docker
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/knowted_db
SPRING_DATASOURCE_USERNAME=knowted
SPRING_DATASOURCE_PASSWORD=knowted_local_password

#OAuth values for local startup
GOOGLE_CLIENT_ID=682046560787-fr2fppqeq4v3n0dhijipkucsffs5m23i.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

#JWT values used by backend
JWT_SECRET=82d32c4b9ecdd88cd7b925c26660bd6b5f148f982bafee22893326f043e04900
JWT_EXPIRATION_MS=3600000

#OAuth redirect URLs
BASE_URL=http://localhost:8080/
FRONTEND_REDIRECT_URL=http://localhost:3000/

#Storage settings for local upload testing (GCS enabled)
STORAGE_PROVIDER=gcs
GCP_BUCKET_NAME=know-ted-bucket
GCS_CREDENTIALS=file:/app/gcs-credentials.json
