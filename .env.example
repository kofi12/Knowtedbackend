# Copy this file to .env.local for local Docker testing.
# Never commit real secrets to git.

# ---------- Postgres ----------
POSTGRES_DB=knowted_db
POSTGRES_USER=knowted
POSTGRES_PASSWORD=knowted_local_password
POSTGRES_HOST_PORT=5433

# ---------- Backend ----------
SPRING_PROFILES_ACTIVE=docker
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/knowted_db
SPRING_DATASOURCE_USERNAME=knowted
SPRING_DATASOURCE_PASSWORD=knowted_local_password

# OAuth placeholders for local startup (replace with real values when needed)
GOOGLE_CLIENT_ID=local-google-client-id
GOOGLE_CLIENT_SECRET=local-google-client-secret
BASE_URL=http://localhost:8080
FRONTEND_REDIRECT_URL=http://localhost:3000

# JWT values used by backend
JWT_SECRET=replace-with-a-32-plus-char-local-secret
JWT_EXPIRATION_MS=3600000

# Storage defaults for local testing (no cloud dependency)
STORAGE_PROVIDER=noop
GCP_BUCKET_NAME=knowted-local-bucket
GCS_CREDENTIALS=/tmp/noop-gcs.json
GCS_CREDENTIALS_FILE=./backend/gcs-credentials.local.json

# ---------- Frontend ----------
VITE_BACKEND_URL=http://localhost:8080